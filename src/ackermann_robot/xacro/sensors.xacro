    <link name="camera_link">
        <inertial>
            <mass value="0.0559" />
            <inertia ixx="0.00013" ixy="1.2e-07" ixz="1.62e-06" iyy="1.91e-05" iyz="-2.8e-08" izz="0.00013" />
        </inertial>
        <visual>
            <geometry> <mesh filename="package://ackermann_robot/meshes/top_akm_bs_robot_meshes/camera_link.STL" /> </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <geometry> <mesh filename="package://ackermann_robot/meshes/top_akm_bs_robot_meshes/camera_link.STL" /> </geometry>
        </collision>
    </link>
    <joint name="camera_joint" type="fixed">
        <origin xyz="0.31239 -3.77e-05 0.1347" rpy="0 0 0" />
        <parent link="base_link" />
        <child link="camera_link" />
    </joint>
    <!-- 虚拟光学关节，矫正ROS机器人和相机光学坐标轴不一致的问题 -->
    <link name="camera_optical_link"/>
    
    <joint name="camera_optical_joint" type="fixed">
        <origin xyz="0.05 0 0" rpy="-1.570796327 0 -1.570796327"/>
        <parent link="camera_link"/>
        <child link="camera_optical_link"/>
    </joint>

    <gazebo reference="camera_link">
        <material>Gazebo/Yellow</material>
        <sensor name="depth_camera" type="depth">
            <pose>0.05 0 0 0 0 0</pose>
            <update_rate>30.0</update_rate>
            <camera>
                <horizontal_fov>1.047198</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>B8G8R8</format>
                </image>
                <clip>
                    <near>0.2</near>
                    <far>4.0</far>
                </clip>
            </camera>
            <plugin name="depth_camera_controller" filename="libgazebo_ros_camera.so">
                <ros>
                    <remapping>custom_camera/image_raw:=color/image_raw</remapping>
                    <remapping>custom_camera/image_depth:=depth/image_raw</remapping>
                    <remapping>custom_camera/camera_info:=color/camera_info</remapping>
                    <remapping>custom_camera/camera_info_depth:=depth/camera_info</remapping>
                    <remapping>custom_camera/points:=depth/points</remapping>
                </ros>
                
                <camera_name>depth_camera</camera_name>
                <frame_name>camera_optical_link</frame_name>
                
                <hack_baseline>0.07</hack_baseline>
                <min_depth>0.2</min_depth>
                <max_depth>4.0</max_depth>
            </plugin>
        </sensor>
    </gazebo>

    <link name="gyro_link">
        <inertial>
             <origin xyz="-0.0226 0.0293 0.0055" rpy="0 0 0" />
            <mass value="0.0236" />
            <inertia ixx="5.41e-06" ixy="-2.2e-14" ixz="-1.81e-09" iyy="4.38e-06" iyz="4.78e-14" izz="9.32e-06" />
        </inertial>
        <visual>
            <geometry> <mesh filename="package://ackermann_robot/meshes/top_akm_bs_robot_meshes/gyro_link.STL" /> </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry> <mesh filename="package://ackermann_robot/meshes/top_akm_bs_robot_meshes/gyro_link.STL" /> </geometry>
        </collision>
    </link>
    <joint name="gyro_joint" type="fixed">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <parent link="base_link" />
        <child link="gyro_link" />
    </joint>

    <gazebo reference="gyro_link">
        <material>Gazebo/Green</material>
        <sensor name="imu_sensor" type="imu">
            <always_on>true</always_on>
            <update_rate>100</update_rate>
            <imu>
                <angular_velocity>
                    <x> <noise type="gaussian"> <mean>0.0</mean> <stddev>2e-4</stddev> </noise> </x>
                    <y> <noise type="gaussian"> <mean>0.0</mean> <stddev>2e-4</stddev> </noise> </y>
                    <z> <noise type="gaussian"> <mean>0.0</mean> <stddev>2e-4</stddev> </noise> </z>
                </angular_velocity>
                <linear_acceleration>
                    <x> <noise type="gaussian"> <mean>0.0</mean> <stddev>1.7e-2</stddev> </noise> </x>
                    <y> <noise type="gaussian"> <mean>0.0</mean> <stddev>1.7e-2</stddev> </noise> </y>
                    <z> <noise type="gaussian"> <mean>0.0</mean> <stddev>1.7e-2</stddev> </noise> </z>
                </linear_acceleration>
            </imu>
            <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
                <ros> <remapping>~/out:=/imu/data</remapping> </ros>
                <frame_name>gyro_link</frame_name>
                <initial_orientation_as_reference>false</initial_orientation_as_reference>
            </plugin>
        </sensor>
    </gazebo>

