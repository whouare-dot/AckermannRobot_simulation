<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <link name="laser_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="1.5" />
            <inertia ixx="0.00395" ixy="0.0" ixz="0.0" iyy="0.00395" iyz="0.0" izz="0.00227" />
        </inertial>
        <visual>
            <geometry> <mesh filename="package://ackermann_robot/meshes/top_akm_bs_robot_meshes/laser_link.STL" /> </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.15" radius="0.055"/>
            </geometry>
        </collision>
    </link>
    <joint name="laser_joint" type="fixed">
        <origin xyz="-0.07777 0.00081 0.3842" rpy="0 0 0" />
        <parent link="base_link" />
        <child link="laser_link" />
    </joint>
    
    <gazebo reference="laser_link">
        <material>Gazebo/Grey</material>
        <sensor type="gpu_ray" name="velodyne_3d_lidar">
            <pose>0 0 0 0 0 0</pose>
            <always_on>true</always_on>
            <visualize>false</visualize>
            <update_rate>20</update_rate>
            <ray>
                <scan>
                    <horizontal>
                        <samples>1800</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.14159265</min_angle>
                        <max_angle>3.14159265</max_angle>
                    </horizontal>
                    <vertical>
                        <samples>16</samples>
                        <resolution>1</resolution>
                        <min_angle>-0.261799</min_angle>
                        <max_angle>0.261799</max_angle>
                    </vertical>
                </scan>
                <range>
                    <min>0.5</min>
                    <max>100.0</max>
                    <resolution>0.03</resolution>
                </range>
                <noise> 
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.03</stddev>
                    </noise>
            </ray>
            <plugin name="gazebo_ros_laser_controller" filename="libgazebo_ros_ray_sensor.so">
                <ros> <remapping>~/out:=/points_raw</remapping> </ros>
                <output_type>sensor_msgs/PointCloud2</output_type>
                <frame_name>laser_link</frame_name>
            </plugin>
            <!-- <plugin filename="libgazebo_ros_ray_sensor.so" name="laserscan">
                <ros>
                    <remapping>~/out:=scan</remapping>
                </ros>
                <output_type>sensor_msgs/LaserScan</output_type>
                <frame_name>laser_link</frame_name>
            </plugin> -->
        </sensor>
    </gazebo>

